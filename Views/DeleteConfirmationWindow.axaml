<Window
    x:Class="RawV.Views.DeleteConfirmationWindow"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Width="400"
    Height="200"
    CanResize="False"
    WindowStartupLocation="CenterOwner"
    Title="Confirm Delete">

  <Panel>
    <Panel.Background>
      <SolidColorBrush Color="#F3F3F3" />
    </Panel.Background>

    <Grid RowDefinitions="*,Auto" Margin="24">
      <StackPanel Spacing="16" VerticalAlignment="Center">
        <StackPanel Orientation="Horizontal" Spacing="12">
          <Border
              Width="40"
              Height="40"
              CornerRadius="20"
              Background="#300078D4">
            <PathIcon
                Data="M19,4H15.5L14.5,3H9.5L8.5,4H5V6H19M6,19A2,2 0 0,0 8,21H16A2,2 0 0,0 18,19V7H6V19Z"
                Width="20"
                Height="20"
                Foreground="#0078D4" />
          </Border>
          <TextBlock
              Text="Confirm Delete"
              FontSize="20"
              FontWeight="SemiBold"
              VerticalAlignment="Center"
              Foreground="#1A1A1A" />
        </StackPanel>
        <TextBlock
            Text="The current image and any associated RAW files will be moved to the Recycle Bin. This action can be undone."
            TextWrapping="Wrap"
            Opacity="0.8"
            Foreground="#1A1A1A"
            LineHeight="24" />
      </StackPanel>

      <StackPanel
          Grid.Row="1"
          Orientation="Horizontal"
          HorizontalAlignment="Right"
          Spacing="8">
        <Button
            Click="OnCancelClick"
            Width="100"
            Height="32">
          <TextBlock Text="Cancel" />
        </Button>
        <Button
            Click="OnConfirmClick"
            Classes="Delete"
            Width="100"
            Height="32">
          <TextBlock Text="Delete" />
        </Button>
      </StackPanel>
    </Grid>
  </Panel>

  <Window.Styles>
    <Style Selector="Button.Delete">
      <Setter Property="Background" Value="#0078D4" />
      <Setter Property="Foreground" Value="White" />
    </Style>

    <Style Selector="Button.Delete:pointerover">
      <Setter Property="Background" Value="#106EBE" />
    </Style>
  </Window.Styles>

</Window>
